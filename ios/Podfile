source 'https://cdn.cocoapods.org/'

# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Required for @react-native-firebase with static libraries
$RNFirebaseAsStaticFramework = true

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'MatchCreators' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # Pin Firebase pods to lockfile versions so CocoaPods does not query CDN for
  # newer specs (e.g. 12.16.0) when jsDelivr/CDN is flaky.
  pod 'FirebaseCore', '12.15.0', :modular_headers => true
  pod 'FirebaseCoreInternal', '12.15.0', :modular_headers => true
  pod 'GoogleUtilities', '8.1.2', :modular_headers => true

  # Google Sign-In (RNGoogleSignin) + static Firebase need module maps on these pods.
  pod 'RecaptchaInterop', :modular_headers => true
  pod 'AppCheckCore', :modular_headers => true
  pod 'AppAuth', :modular_headers => true
  pod 'GTMAppAuth', :modular_headers => true

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
  end
end
